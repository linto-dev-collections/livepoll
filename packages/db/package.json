{
  "name": "@livepoll/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    },
    "./schema": {
      "default": "./src/schema/index.ts"
    },
    "./schema/*": {
      "default": "./src/schema/*.ts"
    }
  },
  "scripts": {
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@libsql/client": "catalog:",
    "@livepoll/env": "workspace:*",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.2",
    "libsql": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@livepoll/config": "workspace:*",
    "drizzle-kit": "^0.31.8",
    "typescript": "^5"
  }
}
