# ============================================================
# livepoll 環境変数
# ============================================================

# --- App Config ---
# Better Auth の cookie は secure + SameSite=none で発行されるため HTTPS origin が必要。
# 既存の開発トンネル URL をそのまま流用している。
# CORS_ORIGIN は HTTP の CORS に加えて、リアルタイム投票（Poll DO）の WebSocket
# Origin 許可リストにも使われる。参加者・ホストの web オリジンを必ず含めること
# （含めないと WS が 1008 forbidden origin で切断される）。複数指定はカンマ区切り。
CORS_ORIGIN=http://localhost:3001
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3001
COOKIE_DOMAIN=
FROM_EMAIL=noreply@example.com

# --- Secrets ---
BETTER_AUTH_SECRET=
RESEND_API_KEY=

# --- Google Sign-in (Better Auth) ---
# scope: openid email profile
# redirect URI は Better Auth 既定の `${BETTER_AUTH_URL}/api/auth/callback/google`
GOOGLE_SIGNIN_CLIENT_ID=
GOOGLE_SIGNIN_CLIENT_SECRET=

# --- Alchemy (ローカル開発用) ---
ALCHEMY_PASSWORD=
